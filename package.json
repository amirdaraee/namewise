{
  "name": "@amirdaraee/namewise",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "namewise": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint .",
    "smoke:generate": "tsx scripts/generate-smoke-corpus.ts",
    "smoke": "npm run build && npm run smoke:generate && node dist/index.js rename smoke-corpus --dry-run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release": "npm run build && npm run test:run && npm version patch",
    "release:minor": "npm run build && npm run test:run && npm version minor",
    "release:major": "npm run build && npm run test:run && npm version major",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "rename",
    "files",
    "smart",
    "content",
    "cli",
    "automation",
    "organization",
    "claude",
    "openai"
  ],
  "author": "ai-rename contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/amirdaraee/namewise.git"
  },
  "bugs": {
    "url": "https://github.com/amirdaraee/namewise/issues"
  },
  "homepage": "https://github.com/amirdaraee/namewise#readme",
  "license": "MIT",
  "description": "AI-powered CLI tool that intelligently renames files based on their content using Claude or OpenAI",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/heic-convert": "2.1.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.3.1",
    "@types/pdfkit": "0.17.5",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "10.4.1",
    "pdfkit": "0.19.0",
    "tsx": "4.22.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "8.61.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "commander": "14.0.3",
    "exceljs": "^4.4.0",
    "exifr": "7.1.3",
    "fs-extra": "11.3.5",
    "heic-convert": "2.1.0",
    "inquirer": "^12.9.4",
    "mammoth": "1.12.0",
    "openai": "^5.19.1",
    "ora": "9.4.0",
    "pdf-extraction": "^1.0.2",
    "pdfjs-dist": "5.4.149"
  },
  "optionalDependencies": {
    "canvas": "3.2.3",
    "pdf-to-png-converter": "3.14.0"
  }
}
